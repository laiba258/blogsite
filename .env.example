# Database Configuration
# For local development, leave these empty to use local SQLite
# For production (Vercel), add your Turso credentials
DATABASE_URL=libsql://your-database-name.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# Session Password (generate a random 32-character string)
NUXT_SESSION_PASSWORD=generate-a-random-32-char-string
